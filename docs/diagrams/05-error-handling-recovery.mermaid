%%{init: {'theme': 'base', 'themeVariables': {'primaryColor': '#4A90D9', 'primaryTextColor': '#fff', 'primaryBorderColor': '#2C5F8A', 'lineColor': '#5B6770', 'secondaryColor': '#F5A623', 'tertiaryColor': '#E8F4FD'}}}%%

flowchart TD
    A["⚠️ Error Occurs"] --> B{"Error Type"}

    B -->|"auth_failed"| C1["'Can't connect to shared memory.<br/>Check your token in Settings →<br/>Plugins → Shared Memory → Configure'"]
    C1 --> C1a["retry_possible: false"]

    B -->|"network_error"| C2["'Network hiccup — couldn't reach GitHub.<br/>I'll try again automatically.'"]
    C2 --> C2a["Auto-retry via<br/>plugin-retry (3 attempts)"]
    C2a -->|"Success"| C2b["✅ Continue normally"]
    C2a -->|"Fail"| C2c["'Still can't connect.<br/>Check your internet and try again.'"]

    B -->|"rate_limit_rest"| C3["'GitHub API limit reached<br/>(5000/hour).'"]
    C3 --> C3a["retry_after_ms from<br/>X-RateLimit-Reset header"]
    C3a --> C3b["'I'll retry in N seconds.<br/>Meanwhile, we can work locally.'"]

    B -->|"rate_limit_search"| C3d["'Search limit reached<br/>(10/minute).'"]
    C3d --> C3e["'Let's wait a minute,<br/>or try a tag-based search instead.'"]

    B -->|"sha_conflict"| C4["SHA mismatch on commit"]
    C4 --> C4a["Auto-retry:<br/>re-read SHA → rebuild → commit"]
    C4a -->|"Success"| C4b["✅ Saved successfully"]
    C4a -->|"3 retries failed"| C4c["'Someone else just updated this file.<br/>Try again in a moment.'"]

    B -->|"concurrent_edit"| C5["update_entry detects<br/>different previous_sha"]
    C5 --> C5a["Show diff_summary:<br/>'Entry was changed since you read it'"]
    C5a --> C5b{"User choice"}
    C5b -->|"Overwrite"| C5c["Retry with current SHA"]
    C5b -->|"Cancel"| C5d["Show current version"]
    C5b -->|"Merge"| C5e["Claude merges changes"]

    B -->|"parse_error"| C6["root.md corrupted"]
    C6 --> C6a["Set corrupted: true flag"]
    C6a --> C6b["'root.md format issue detected.<br/>Admin can fix it in GitHub.'"]

    B -->|"Context loss<br/>(long session)"| C7["State file recovery"]
    C7 --> C7a["'Looks like I lost track of<br/>our shared memory context.<br/>Reconnecting now...'"]
    C7a --> C7b["Re-read state file<br/>→ connect_repo → switch_project"]
    C7b --> C7c["✅ Context restored"]

    style A fill:#E67E22,color:#fff
    style C2b fill:#27AE60,color:#fff
    style C4b fill:#27AE60,color:#fff
    style C7c fill:#27AE60,color:#fff
    style C2c fill:#E74C3C,color:#fff
    style C4c fill:#E74C3C,color:#fff
