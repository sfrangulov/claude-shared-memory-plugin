%%{init: {'theme': 'base', 'themeVariables': {'primaryColor': '#4A90D9', 'primaryTextColor': '#fff', 'primaryBorderColor': '#2C5F8A', 'lineColor': '#5B6770', 'secondaryColor': '#F5A623', 'tertiaryColor': '#E8F4FD'}}}%%

flowchart TD
    A["✏️ User: 'Remember this<br/>for the team'"] --> A0{"Step 0:<br/>Local or shared?"}
    A0 -->|"Local"| A0a["Save to local memory<br/>(outside plugin scope)"]
    A0 -->|"Shared"| B{"Active project<br/>set?"}
    B -->|"No"| B1["Combined prompt:<br/>select project from list"]
    B1 --> B2["switch_project"]
    B -->|"Yes"| C
    B2 --> C{"Project or _shared?"}
    C -->|"Skill decides<br/>by content"| D["check_duplicate"]
    D --> D1{"Similar entry<br/>found?"}
    D1 -->|"Yes"| D2["Show match with reason:<br/>'Matched by tags: auth, jwt'"]
    D2 --> D3{"User choice"}
    D3 -->|"Update existing"| D4["→ update_entry flow"]
    D3 -->|"Create new"| E
    D1 -->|"No"| E["Skill suggests tags<br/>(top 5 from existing)"]
    E --> F["User confirms/edits<br/>title, tags, content"]
    F --> G["write_entry"]
    G --> G1["Generate slug from title"]
    G1 --> G2["Create entry file<br/>from _meta.md template"]
    G2 --> G3{"auto_related?"}
    G3 -->|"Yes"| G4["Find entries with<br/>≥1 common tag"]
    G4 --> G5{"Count?"}
    G5 -->|"1-3"| G6["Auto-add Related section"]
    G5 -->|">3"| G7["Show candidates,<br/>user selects"]
    G5 -->|"0"| G8["No Related section"]
    G3 -->|"No / override"| G8

    G6 --> H["Atomic commit:<br/>blob → tree → commit → ref"]
    G7 --> H
    G8 --> H

    H --> H1{"SHA conflict?"}
    H1 -->|"No"| I["✅ Entry saved<br/>+ root.md updated"]
    H1 -->|"422 SHA mismatch"| H2["Retry: re-read SHA<br/>→ rebuild tree → commit"]
    H2 --> H3{"Retry OK?"}
    H3 -->|"Yes"| I
    H3 -->|"No (3 retries)"| H4["❌ sha_conflict error<br/>'Try again in a moment'"]

    style A fill:#4A90D9,color:#fff
    style I fill:#27AE60,color:#fff
    style H4 fill:#E74C3C,color:#fff
